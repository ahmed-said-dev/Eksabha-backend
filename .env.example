NODE_ENV=development
APP_NAME=fantasy-world-cup-backend
PORT=4400
CORS_ORIGIN=http://localhost:8081,http://localhost:19006,http://localhost:3000

ACTIVE_COMPETITION_KEY=world-cup-2026
ACTIVE_COMPETITION_NAME=FIFA World Cup 2026
ACTIVE_COMPETITION_SLUG=world-cup-2026
ACTIVE_COMPETITION_FORMAT=world_cup
ACTIVE_COMPETITION_COUNTRY=
ACTIVE_COMPETITION_YEAR=2026
ACTIVE_COMPETITION_CURRENT_PHASE=group_stage_md1
ACTIVE_COMPETITION_CURRENT_MATCHDAY_NUMBER=1
ACTIVE_COMPETITION_TOTAL_GROUPS=12
ACTIVE_COMPETITION_TOTAL_TEAMS=48
ACTIVE_COMPETITION_STARTS_AT=2026-06-11T18:00:00.000Z
ACTIVE_COMPETITION_ENDS_AT=2026-07-19T18:00:00.000Z

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=fantasy_world_cup
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_SSL=false

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

JWT_ACCESS_TOKEN_SECRET=change-me-access-secret
JWT_ACCESS_TOKEN_EXPIRES_IN=7d
JWT_REFRESH_TOKEN_SECRET=change-me-refresh-secret
ADMIN_EMAIL=admin@worldcupfantasy.local
ADMIN_PASSWORD=Admin123!
ADMIN_DISPLAY_NAME=Platform Administrator

EXTERNAL_FEED_BASE_URL=
EXTERNAL_FEED_API_KEY=
EXTERNAL_FEED_SYNC_SECRET=
EXTERNAL_FEED_AUTO_SYNC_ENABLED=false
EXTERNAL_FEED_SYNC_INTERVAL_SECONDS=30
EXTERNAL_FEED_AUTO_SYNC_ON_BOOT=true

